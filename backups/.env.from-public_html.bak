# =============================================================================
# FlixCam.rent — PRODUCTION .env
# Replace all placeholders (your-*, sk_*, pk_*, whsec_*, etc.) with real values.
# Never commit real secrets. Keep this file in .gitignore.
# =============================================================================

# Database (production — use strong password, consider connection pooling)
DATABASE_URL="postgresql://flixcam:qOHgDzf8YNg07QROMv2PJcGY@localhost:5432/flixcam_rent?schema=public"

# NextAuth v5
AUTH_SECRET="j9btQ+qBF5jhTdSKaeJ4MDIJfvExOtfhY/Vhjpwgaz0="
NEXTAUTH_SECRET="j9btQ+qBF5jhTdSKaeJ4MDIJfvExOtfhY/Vhjpwgaz0="
NEXTAUTH_URL="https://flixcam.rent"

# Cron jobs (required for /api/cron/*)
CRON_SECRET="j9btQ+qBF5jhTdSKaeJ4MDIJfvExOtfhY/Vhjpwgaz0="

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Tap Payments (use LIVE keys in production)
TAP_API_KEY=your-tap-key
TAP_SECRET_KEY="sk_live_..."
TAP_PUBLIC_KEY="pk_live_..."
TAP_WEBHOOK_SECRET="whsec_..."

# Email Configuration (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="noreply@flixcam.rent"
SMTP_FROM_NAME="FlixCam.rent"

# Email Configuration (Gmail OAuth - Alternative)
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
GMAIL_REFRESH_TOKEN=""

# Email Configuration (Hotmail/Outlook - Alternative)
HOTMAIL_CLIENT_ID=""
HOTMAIL_CLIENT_SECRET=""
HOTMAIL_REFRESH_TOKEN=""

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN=""

# Analytics & Tracking
GTM_CONTAINER_ID="GTM-XXXXXXX"
GA4_MEASUREMENT_ID="G-XXXXXXXXXX"
META_PIXEL_ID=""

# OpenAI (Phase 2 - AI Features)
OPENAI_API_KEY=""

# Google Gemini (Phase 2 - AI Features - Alternative)
GEMINI_API_KEY=""

# AI Provider Selection (for bulk import autofill)
# Options: "openai" or "gemini"
AI_PROVIDER="gemini"

# Redis (for rate limiting, caching, and BullMQ job queues)
REDIS_URL="redis://localhost:6379"

# Cloudinary (for image processing in bulk imports)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# File Storage
STORAGE_TYPE="local"
# For cloud storage: STORAGE_TYPE="s3" and set AWS_* below
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION=""
# AWS_S3_BUCKET=""

# ZATCA
ZATCA_API_URL=https://api.zatca.gov.sa
ZATCA_API_KEY=your-zatca-key
ZATCA_COMPANY_VAT=300012345600003
ZATCA_COMPANY_CR=1010123456

# Application — PRODUCTION
APP_ENV="production"
APP_URL="https://flixcam.rent"
APP_NAME="FlixCam.rent"
NEXT_PUBLIC_APP_URL=https://flixcam.rent

# Feature Flags (can be overridden in database)
ENABLE_BOOKING_CHECKOUT="true"
ENABLE_PAYMENTS="true"
ENABLE_WHATSAPP="false"
ENABLE_AI_RECOMMENDATIONS="false"

# Rate Limiting (production — adjust as needed)
RATE_LIMIT_API_REQUESTS_PER_HOUR="500"
RATE_LIMIT_AUTH_ATTEMPTS_PER_15MIN="10"

# Upstash Redis (optional — for serverless rate limiting/caching)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Sentry (Error tracking)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# Security — production origins only
ALLOWED_ORIGINS="https://flixcam.rent,https://www.flixcam.rent"

# Next.js (dev/build)
# Suppress "lockfile missing swc dependencies" when lockfile was generated on another platform
NEXT_IGNORE_INCORRECT_LOCKFILE=true

# Logging
LOG_LEVEL="warn"
ENABLE_AUDIT_LOGGING="true"
