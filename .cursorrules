## 💻 Code Style & Structure

### TypeScript Rules

```typescript
// ✅ ALWAYS: Use TypeScript for all code
// ✅ ALWAYS: Use interfaces for objects, types for unions/primitives
// ✅ ALWAYS: Avoid 'any' and 'unknown'
// ✅ ALWAYS: Define return types for functions

// ✅ GOOD - Interfaces for object shapes
interface BookingData {
  equipmentIds: string[]
  startDate: Date
  endDate: Date
  customerId: string
}

interface BookingService {
  create(data: BookingData): Promise<Booking>
  findById(id: string): Promise<Booking | null>
  update(id: string, data: Partial<BookingData>): Promise<Booking>
}

// ✅ GOOD - Types for unions, primitives, utilities
type BookingStatus = 'draft' | 'confirmed' | 'active' | 'returned' | 'cancelled'
type Result<T> = { success: true; data: T } | { success: false; error: string }
type Nullable<T> = T | null

// ❌ AVOID - Enums (use const objects instead)
enum BookingStatus { Draft, Confirmed } // ❌

// ✅ USE - Const objects with 'as const'
const BOOKING_STATUS = {
  DRAFT: 'draft',
  CONFIRMED: 'confirmed',
  ACTIVE: 'active',
  RETURNED: 'returned',
  CANCELLED: 'cancelled',
} as const

type BookingStatus = typeof BOOKING_STATUS[keyof typeof BOOKING_STATUS]

// ✅ GOOD - Explicit return types
function calculateTotal(items: LineItem[]): number {
  return items.reduce((sum, item) => sum + item.price * item.quantity, 0)
}

// ✅ GOOD - Avoid type assertions (use type guards instead)
function isBooking(value: unknown): value is Booking {
  return (
    typeof value === 'object' &&
    value !== null &&
    'id' in value &&
    'status' in value
  )
}

// Use it
if (isBooking(data)) {
  // TypeScript knows data is Booking here
  console.log(data.status)
}
```

### Component Patterns

```typescript
// ✅ USE: Function keyword for components
function BookingCard({ booking }: BookingCardProps) {
  return <div>{booking.id}</div>
}

// ❌ AVOID: Arrow functions for components
const BookingCard = ({ booking }: BookingCardProps) => {
  return <div>{booking.id}</div>
}

// ✅ USE: Const for event handlers
const handleClick = () => {
  console.log('clicked')
}

const handleSubmit = async (data: FormData) => {
  await submitForm(data)
}

// ✅ USE: Descriptive names with auxiliary verbs
const isLoading = true
const hasError = false
const canSubmit = !isLoading && !hasError
const shouldShowWarning = total > 10000

// ✅ USE: Early returns for readability
function processBooking(booking: Booking) {
  if (!booking) {
    return null
  }
  
  if (booking.status === 'cancelled') {
    return <CancelledMessage />
  }
  
  if (!booking.isPaid) {
    return <PaymentRequired />
  }
  
  // Happy path last
  return <BookingDetails booking={booking} />
}

// ✅ USE: Guard clauses
async function createBooking(data: BookingData, userId: string) {
  // Guards at the top
  if (!data.equipmentIds.length) {
    throw new ValidationError('Equipment required')
  }
  
  if (!await hasPermission(userId, 'booking.create')) {
    throw new ForbiddenError()
  }
  
  if (!await checkAvailability(data.equipmentIds, data.startDate, data.endDate)) {
    throw new ConflictError('Equipment not available')
  }
  
  // Happy path last
  const booking = await BookingService.create(data, userId)
  return booking
}
```

### Naming Conventions

```typescript
// ✅ Files: kebab-case
booking-form.tsx
equipment-card.tsx
payment-service.ts

// ✅ Components: PascalCase
function BookingForm() {}
function EquipmentCard() {}

// ✅ Functions/Variables: camelCase
const calculateTotal = () => {}
