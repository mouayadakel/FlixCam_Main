### Component File Structure (MANDATORY ORDER)

```typescript
// 1. IMPORTS - Grouped and ordered
import { type ReactNode } from 'react'
import { useRouter } from 'next/navigation'

// External libraries
import { z } from 'zod'
import { useForm } from 'react-hook-form'

// Internal - absolute imports
import { Button } from '@/components/ui/button'
import { BookingService } from '@/lib/services/booking.service'
import { createBookingSchema } from '@/lib/validators/booking.validator'

// Types
import type { Booking, Equipment } from '@/lib/types'

// 2. TYPES & INTERFACES - Before component
interface BookingFormProps {
  equipmentId: string
  onSuccess?: (booking: Booking) => void
  onError?: (error: Error) => void
}

interface BookingFormState {
  isSubmitting: boolean
  error: string | null
}

// 3. CONSTANTS - Static data
const BOOKING_STATUS_OPTIONS = [
  { value: 'draft', label: 'Draft' },
  { value: 'confirmed', label: 'Confirmed' },
  { value: 'active', label: 'Active' },
] as const

const DEFAULT_RENTAL_DURATION = 7 // days

// 4. MAIN COMPONENT - Use function keyword
function BookingForm({ equipmentId, onSuccess, onError }: BookingFormProps) {
  // 4a. Hooks - Always at the top, same order
  const router = useRouter()
  const [state, setState] = useState<BookingFormState>({
    isSubmitting: false,
    error: null,
  })
  
  const form = useForm({
    resolver: zodResolver(createBookingSchema),
    defaultValues: {
      equipmentId,
      duration: DEFAULT_RENTAL_DURATION,
    },
  })
  
  // 4b. Event handlers - Use const with 'handle' prefix
  const handleSubmit = async (data: z.infer<typeof createBookingSchema>) => {
    setState({ isSubmitting: true, error: null })
    
    try {
      const booking = await BookingService.create(data)
      onSuccess?.(booking)
      router.push(`/bookings/${booking.id}`)
    } catch (error) {
      const errorMessage = error instanceof Error ? error.message : 'Failed to create booking'
      setState({ isSubmitting: false, error: errorMessage })
      onError?.(error as Error)
    }
  }
  
  const handleCancel = () => {
    form.reset()
    router.back()
  }
  
  // 4c. Render
  return (
    <form onSubmit={form.handleSubmit(handleSubmit)} className="space-y-6">
      {/* Form fields */}
    </form>
  )
}

// 5. SUB-COMPONENTS - After main component
function BookingFormField({ label, error, children }: BookingFormFieldProps) {
  return (
    <div className="space-y-2">
      <label className="text-sm font-medium">{label}</label>
      {children}
      {error && <p className="text-sm text-red-500">{error}</p>}
    </div>
  )
}

// 6. EXPORTS - Named exports at the end
export { BookingForm, type BookingFormProps }
```

