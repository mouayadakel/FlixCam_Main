## 🏛️ Architecture Patterns

### Service Layer (MANDATORY)

```typescript
// ✅ ALL business logic goes in services
// /lib/services/booking.service.ts

interface CreateBookingInput {
  equipmentIds: string[]
  startDate: Date
  endDate: Date
  customerId: string
}

export class BookingService {
  /**
   * Creates a new booking with full validation and workflow
   * @param data - Booking data
   * @param userId - User creating the booking
   * @returns Created booking
   * @throws {ValidationError} If data is invalid
   * @throws {ForbiddenError} If user lacks permissions
   * @throws {ConflictError} If equipment unavailable
   */
  static async create(data: CreateBookingInput, userId: string): Promise<Booking> {
    // 1. Validate input
    const validated = createBookingSchema.parse(data)
    
    // 2. Check permissions
    if (!await hasPermission(userId, 'booking.create')) {
      throw new ForbiddenError('Missing permission: booking.create')
    }
    
    // 3. Business logic - Check availability
    const isAvailable = await this.checkAvailability(
      validated.equipmentIds,
      validated.startDate,
      validated.endDate
    )
    
    if (!isAvailable) {
      throw new ConflictError('Equipment not available for selected dates')
    }
    
    // 4. Create soft lock
    await InventoryService.createSoftLock(validated.equipmentIds, userId)
    
    // 5. Create booking in transaction
    const booking = await prisma.$transaction(async (tx) => {
      const created = await tx.booking.create({
        data: {
          ...validated,
          status: 'draft',
          createdById: userId,
          createdAt: new Date(),
        },
        include: {
          equipment: true,
          customer: true,
        }
      })
      
      // Update equipment status
      await tx.equipment.updateMany({
        where: { id: { in: validated.equipmentIds } },
        data: { status: 'reserved' }
      })
      
      return created
    })
    
    // 6. Emit event
    await EventBus.emit('booking.created', {
      booking,
      userId,
      timestamp: new Date()
    })
    
    return booking
  }
  
  /**
   * Checks equipment availability for date range
   */
  private static async checkAvailability(
    equipmentIds: string[],
    startDate: Date,
    endDate: Date
  ): Promise<boolean> {
    const conflicts = await prisma.booking.count({
      where: {
        equipmentIds: { hasSome: equipmentIds },
        status: { in: ['confirmed', 'active'] },
        OR: [
          {
            startDate: { lte: endDate },
            endDate: { gte: startDate }
          }
        ],
        deletedAt: null
      }
    })
    
    return conflicts === 0
  }
}
```

### Policy Layer (MANDATORY)

```typescript
// /lib/policies/booking.policy.ts

export class BookingPolicy {
  /**
   * Check if user can create bookings
   */
  static async canCreate(userId: string): Promise<PolicyResult> {
    const hasPermission = await hasPermission(userId, 'booking.create')
    
    if (!hasPermission) {
      return {
        allowed: false,
        reason: 'Missing permission: booking.create'
      }
    }
    
    return { allowed: true }
  }
  
  /**
   * Check if user can edit a specific booking
   */
  static async canEdit(userId: string, booking: Booking): Promise<PolicyResult> {
    // Cannot edit confirmed/active bookings
    if (['confirmed', 'active'].includes(booking.status)) {
      return {
        allowed: false,
        reason: 'Cannot edit confirmed or active bookings'
      }
    }
    
    // Must have permission
    if (!await hasPermission(userId, 'booking.edit')) {
      return {
        allowed: false,
        reason: 'Missing permission: booking.edit'
      }
    }
    
    // Customer service can only edit draft bookings
    const user = await UserService.findById(userId)
    if (user.role === 'customer-service' && booking.status !== 'draft') {
      return {
        allowed: false,
        reason: 'Customer service can only edit draft bookings'
      }
    }
    
    return { allowed: true }
  }
  
  /**
   * Check if user can delete a booking
   */
  static async canDelete(userId: string, booking: Booking): Promise<PolicyResult> {
    // NEVER delete confirmed/active bookings
    if (['confirmed', 'active'].includes(booking.status)) {
      return {
        allowed: false,
        reason: 'Cannot delete confirmed or active bookings. Cancel instead.'
      }
    }
    
    if (!await hasPermission(userId, 'booking.delete')) {
      return {
        allowed: false,
        reason: 'Missing permission: booking.delete'
      }
    }
    
    return { allowed: true }
  }
}

// Policy result type
interface PolicyResult {
  allowed: boolean
  reason?: string
}
```

### Validator Layer (MANDATORY)

```typescript
// /lib/validators/booking.validator.ts
import { z } from 'zod'

export const createBookingSchema = z.object({
  equipmentIds: z
    .array(z.string().cuid())
    .min(1, 'At least one equipment item required'),
  
  startDate: z
    .date()
    .min(new Date(), 'Start date must be in the future'),
  
  endDate: z.date(),
  
  customerId: z.string().cuid(),
  
  projectType: z.enum(['commercial', 'personal', 'educational']),
  
  notes: z.string().max(500).optional(),
  
  depositAmount: z
    .number()
    .positive()
    .optional(),
}).refine(
  (data) => data.endDate > data.startDate,
  {
    message: 'End date must be after start date',
    path: ['endDate'],
  }
).refine(
  (data) => {
    const duration = differenceInDays(data.endDate, data.startDate)
    return duration <= 365
  },
  {
    message: 'Rental duration cannot exceed 365 days',
    path: ['endDate'],
  }
)

export const updateBookingSchema = createBookingSchema.partial()

export type CreateBookingInput = z.infer<typeof createBookingSchema>
export type UpdateBookingInput = z.infer<typeof updateBookingSchema>
```

### Event System (MANDATORY)

```typescript
// /lib/events/event-bus.ts

type EventName = 
  | 'booking.created'
  | 'booking.confirmed'
  | 'booking.cancelled'
  | 'payment.processed'
  | 'payment.refunded'
  | 'equipment.damaged'
  | 'contract.signed'

interface EventPayload {
  'booking.created': { booking: Booking; userId: string }
  'booking.confirmed': { booking: Booking; userId: string }
  'payment.processed': { payment: Payment; booking: Booking }
  'payment.refunded': { payment: Payment; reason: string }
}

export class EventBus {
  /**
   * Emit an event to all registered handlers
   */
  static async emit<T extends EventName>(
    event: T,
    payload: EventPayload[T]
  ): Promise<void> {
    // Log event
    await AuditService.logEvent({
      eventName: event,
      payload,
      timestamp: new Date()
    })
    
    // Get handlers for this event
    const handlers = this.getHandlers(event)
    
    // Execute all handlers (async, non-blocking)
    await Promise.allSettled(
      handlers.map(handler => handler(payload))
    )
  }
  
  private static getHandlers(event: EventName): Array<(payload: any) => Promise<void>> {
    // Return registered handlers
    return eventHandlers[event] || []
  }
}

// /lib/events/handlers/booking-handlers.ts
export async function handleBookingCreated(payload: EventPayload['booking.created']) {
  const { booking, userId } = payload
  
  // Send confirmation email
  await EmailService.send({
    to: booking.customer.email,
    template: 'booking-created',
    data: { booking }
  })
  
  // Notify warehouse
  await NotificationService.notify({
    recipientRoles: ['warehouse-manager'],
    message: `New booking created: ${booking.id}`,
    type: 'info'
  })
  
  // Update analytics
  await AnalyticsService.track({
    event: 'booking_created',
    properties: {
      bookingId: booking.id,
      equipmentCount: booking.equipmentIds.length,
      totalValue: booking.totalPrice
    }
  })
}
```

