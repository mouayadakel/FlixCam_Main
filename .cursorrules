## 🗄️ Database Patterns

### Prisma Schema Rules

```prisma
// ✅ ALWAYS include audit fields
model Booking {
  id          String   @id @default(cuid())
  
  // Relationships
  equipment   Equipment[]
  customer    User      @relation("CustomerBookings", fields: [customerId], references: [id])
  customerId  String
  
  // Business fields
  status      BookingStatus
  startDate   DateTime
  endDate     DateTime
  totalPrice  Decimal   @db.Decimal(10, 2)
  
  // Audit fields (MANDATORY)
  createdAt   DateTime  @default(now())
  createdBy   String
  updatedAt   DateTime  @updatedAt
  updatedBy   String?
  deletedAt   DateTime?  // Soft delete
  deletedBy   String?
  
  // Indexes for performance
  @@index([customerId])
  @@index([status])
  @@index([startDate, endDate])
  @@index([deletedAt]) // For soft delete queries
  @@index([createdAt])
}

enum BookingStatus {
  DRAFT
  RISK_CHECK
  PAYMENT_PENDING
  CONFIRMED
  ACTIVE
  RETURNED
  CLOSED
  CANCELLED
}
```

### Query Patterns

```typescript
// ✅ ALWAYS filter soft-deleted records
async function getBookings(userId: string) {
  return await prisma.booking.findMany({
    where: {
      customerId: userId,
      deletedAt: null // MANDATORY soft delete filter
    },
    include: {
      equipment: {
        select: { id: true, name: true, dailyRate: true }
      },
      customer: {
        select: { id: true, name: true, email: true }
      }
    },
    orderBy: { createdAt: 'desc' }
  })
}

// ✅ Use transactions for multi-step operations
async function confirmBooking(bookingId: string, userId: string) {
  return await prisma.$transaction(async (tx) => {
    // 1. Update booking
    const booking = await tx.booking.update({
      where: { id: bookingId },
      data: { 
        status: 'CONFIRMED',
        confirmedAt: new Date(),
        confirmedBy: userId,
        updatedAt: new Date(),
        updatedBy: userId
      }
    })
    
    // 2. Lock equipment
    await tx.equipment.updateMany({
      where: { 
        id: { in: booking.equipmentIds },
        deletedAt: null
      },
      data: { 
        status: 'LOCKED',
        updatedAt: new Date()
      }
    })
    
    // 3. Create contract
    await tx.contract.create({
      data: {
        bookingId,
        status: 'PENDING_SIGNATURE',
        createdAt: new Date(),
        createdBy: userId
      }
    })
    
    return booking
  })
}

// ✅ Handle errors properly
async function findBookingById(id: string): Promise<Booking | null> {
  try {
    return await prisma.booking.findUnique({
      where: { id, deletedAt: null },
      include: { equipment: true, customer: true }
    })
  } catch (error) {
    if (error instanceof Prisma.PrismaClientKnownRequestError) {
      if (error.code === 'P2025') {
        return null // Record not found
      }
    }
    throw error
  }
}
```

