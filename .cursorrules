## 📁 Component Documentation (MANDATORY)

Every component MUST have JSDoc comments:

```typescript
/**
 * BookingForm - Form for creating new equipment bookings
 * 
 * This component handles the complete booking creation workflow including:
 * - Equipment selection
 * - Date range validation
 * - Availability checking
 * - Deposit calculation
 * - Permission verification
 * 
 * @component
 * @example
 * ```tsx
 * <BookingForm
 *   equipmentId="eq_123"
 *   onSuccess={(booking) => router.push(`/bookings/${booking.id}`)}
 *   onError={(error) => toast.error(error.message)}
 * />
 * ```
 */
interface BookingFormProps {
  /** ID of pre-selected equipment (optional) */
  equipmentId?: string
  
  /** Callback fired when booking is successfully created */
  onSuccess?: (booking: Booking) => void
  
  /** Callback fired when booking creation fails */
  onError?: (error: Error) => void
  
  /** Additional CSS classes */
  className?: string
}

function BookingForm({ 
  equipmentId, 
  onSuccess, 
  onError,
  className 
}: BookingFormProps) {
  // Implementation
}

/**
 * Calculate total rental cost including taxes and fees
 * 
 * @param items - Line items to calculate
 * @param taxRate - Tax rate (e.g., 0.15 for 15%)
 * @returns Total cost including tax
 * 
 * @example
 * ```ts
 * const total = calculateTotal(items, 0.15)
 * // Returns: 1150 (1000 + 15% tax)
 * ```
 */
function calculateTotal(items: LineItem[], taxRate: number): number {
  const subtotal = items.reduce((sum, item) => sum + item.price * item.quantity, 0)
  const tax = subtotal * taxRate
  return subtotal + tax
}
```

