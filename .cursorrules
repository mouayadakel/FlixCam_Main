## 🔑 State Management

### Zustand for Global State

```typescript
// /lib/stores/booking.store.ts
import { create } from 'zustand'
import { devtools, persist } from 'zustand/middleware'

interface BookingState {
  // State
  currentBooking: Booking | null
  selectedEquipment: Equipment[]
  
  // Actions
  setCurrentBooking: (booking: Booking | null) => void
  addEquipment: (equipment: Equipment) => void
  removeEquipment: (equipmentId: string) => void
  clearSelection: () => void
}

export const useBookingStore = create<BookingState>()(
  devtools(
    persist(
      (set) => ({
        currentBooking: null,
        selectedEquipment: [],
        
        setCurrentBooking: (booking) => set({ currentBooking: booking }),
        
        addEquipment: (equipment) => set((state) => ({
          selectedEquipment: [...state.selectedEquipment, equipment]
        })),
        
        removeEquipment: (equipmentId) => set((state) => ({
          selectedEquipment: state.selectedEquipment.filter(e => e.id !== equipmentId)
        })),
        
        clearSelection: () => set({ 
          selectedEquipment: [],
          currentBooking: null
        })
      }),
      {
        name: 'booking-storage'
      }
    )
  )
)

// Usage in component
function EquipmentSelector() {
  const { selectedEquipment, addEquipment, removeEquipment } = useBookingStore()
  
  return (
    <div>
      {selectedEquipment.map(item => (
        <div key={item.id}>
          {item.name}
          <button onClick={() => removeEquipment(item.id)}>Remove</button>
        </div>
      ))}
    </div>
  )
}
```

### TanStack Query for Server State

```typescript
// /lib/hooks/use-bookings.ts
import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query'

export function useBookings(userId: string) {
  return useQuery({
    queryKey: ['bookings', userId],
    queryFn: async () => {
      const response = await fetch(`/api/bookings?userId=${userId}`)
      if (!response.ok) throw new Error('Failed to fetch bookings')
      return response.json()
    },
    staleTime: 5 * 60 * 1000, // 5 minutes
  })
}

export function useCreateBooking() {
  const queryClient = useQueryClient()
  
  return useMutation({
    mutationFn: async (data: CreateBookingInput) => {
      const response = await fetch('/api/bookings', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      })
      
      if (!response.ok) {
        const error = await response.json()
        throw new Error(error.message)
      }
      
      return response.json()
    },
    onSuccess: () => {
      // Invalidate bookings query
      queryClient.invalidateQueries({ queryKey: ['bookings'] })
    }
  })
}

// Usage in component
function BookingsList() {
  const { data: bookings, isLoading, error } = useBookings('user_1')
  
  if (isLoading) return <LoadingSpinner />
  if (error) return <ErrorMessage error={error} />
  
  return (
    <div>
      {bookings.map(booking => (
        <BookingCard key={booking.id} booking={booking} />
      ))}
    </div>
  )
}
```

