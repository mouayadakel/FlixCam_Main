## 🚨 Error Handling

### Custom Error Classes

```typescript
// /lib/errors.ts

export class AppError extends Error {
  constructor(
    public message: string,
    public statusCode: number = 500,
    public code?: string,
    public metadata?: Record<string, any>
  ) {
    super(message)
    this.name = this.constructor.name
    Error.captureStackTrace(this, this.constructor)
  }
}

export class ValidationError extends AppError {
  constructor(message: string, public errors?: any) {
    super(message, 400, 'VALIDATION_ERROR', { errors })
  }
}

export class ForbiddenError extends AppError {
  constructor(message = 'Forbidden', public permission?: string) {
    super(message, 403, 'FORBIDDEN', { permission })
  }
}

export class ConflictError extends AppError {
  constructor(message: string) {
    super(message, 409, 'CONFLICT')
  }
}

export class PolicyViolationError extends AppError {
  constructor(message: string, public policyName?: string) {
    super(message, 403, 'POLICY_VIOLATION', { policyName })
  }
}

export class ApprovalRequiredError extends AppError {
  constructor(message = 'Approval required', public approvalType?: string) {
    super(message, 403, 'APPROVAL_REQUIRED', { approvalType })
  }
}
```

### Error Handler

```typescript
// /lib/error-handler.ts

export function handleError(error: unknown): Response {
  // Log error to monitoring service
  console.error('[Error]', error)
  
  // AppError instances
  if (error instanceof AppError) {
    return Response.json(
      { 
        error: error.message, 
        code: error.code,
        ...error.metadata
      },
      { status: error.statusCode }
    )
  }
  
  // Zod validation errors
  if (error instanceof z.ZodError) {
    return Response.json(
      { 
        error: 'Validation failed', 
        code: 'VALIDATION_ERROR',
        details: error.errors
      },
      { status: 400 }
    )
  }
  
  // Prisma errors
  if (error instanceof Prisma.PrismaClientKnownRequestError) {
    if (error.code === 'P2002') {
      return Response.json(
        { error: 'Unique constraint violation', code: 'CONFLICT' },
        { status: 409 }
      )
    }
  }
  
  // Unknown errors
  return Response.json(
    { error: 'Internal server error', code: 'INTERNAL_ERROR' },
    { status: 500 }
  )
}
```

