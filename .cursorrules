## 🔐 Security Rules (NON-NEGOTIABLE)

### Rule 1: No Admin Bypass

```typescript
// ❌ NEVER DO THIS - Admin bypass
if (user.role === 'admin') return true
if (user.isAdmin()) return true

// ✅ ALWAYS DO THIS - Use policies for everyone
async function canDeleteBooking(userId: string, bookingId: string) {
  const booking = await prisma.booking.findUnique({ where: { id: bookingId } })
  
  // Policy applies to EVERYONE including admin
  if (['confirmed', 'active'].includes(booking.status)) {
    return { allowed: false, reason: 'Cannot delete confirmed/active bookings' }
  }
  
  // Permission check
  return { 
    allowed: await hasPermission(userId, 'booking.delete'),
    reason: 'Permission required: booking.delete'
  }
}
```

### Rule 2: All Financial Operations Require Approval

```typescript
// ❌ NEVER DO THIS - Direct refund
async function refundPayment(paymentId: string) {
  await prisma.payment.update({
    where: { id: paymentId },
    data: { status: 'refunded' }
  })
}

// ✅ ALWAYS DO THIS - Approval workflow
async function refundPayment(paymentId: string, userId: string, reason: string) {
  // 1. Permission check
  if (!await hasPermission(userId, 'payment.refund')) {
    throw new ForbiddenError('Missing permission: payment.refund')
  }
  
  // 2. Request approval
  const approval = await ApprovalService.request({
    action: 'payment.refund',
    resourceType: 'payment',
    resourceId: paymentId,
    requestedBy: userId,
    reason,
    requiresRoles: ['admin', 'finance-director'],
    metadata: { amount: payment.amount }
  })
  
  if (!approval.approved) {
    throw new ApprovalRequiredError('Refund requires admin approval')
  }
  
  // 3. Execute with audit
  await AuditService.log({
    action: 'payment.refund',
    userId,
    resourceType: 'payment',
    resourceId: paymentId,
    reason,
    approvalId: approval.id,
    metadata: { amount: payment.amount }
  })
  
  // 4. Execute transaction
  const refundedPayment = await prisma.$transaction(async (tx) => {
    const payment = await tx.payment.update({
      where: { id: paymentId },
      data: { 
        status: 'refunded',
        refundedAt: new Date(),
        refundedBy: userId,
        refundReason: reason
      }
    })
    
    // Update booking status
    await tx.booking.update({
      where: { id: payment.bookingId },
      data: { status: 'cancelled' }
    })
    
    return payment
  })
  
  // 5. Emit event
  await EventBus.emit('payment.refunded', {
    payment: refundedPayment,
    userId,
    approvalId: approval.id
  })
  
  return refundedPayment
}
```

### Rule 3: No Hard Delete (Soft Delete Only)

```typescript
// ❌ NEVER DO THIS - Hard delete
await prisma.booking.delete({ where: { id } })

// ✅ ALWAYS DO THIS - Soft delete
async function deleteBooking(bookingId: string, userId: string) {
  // 1. Check policy
  const canDelete = await BookingPolicy.canDelete(userId, bookingId)
  if (!canDelete.allowed) {
    throw new PolicyViolationError(canDelete.reason)
  }
  
  // 2. Audit log
  await AuditService.log({
    action: 'booking.delete',
    userId,
    resourceType: 'booking',
    resourceId: bookingId
  })
  
  // 3. Soft delete
  const booking = await prisma.booking.update({
    where: { id: bookingId },
    data: {
      deletedAt: new Date(),
      deletedBy: userId,
      status: 'cancelled'
    }
  })
  
  // 4. Emit event
  await EventBus.emit('booking.deleted', { booking, userId })
  
  return booking
}

// Exception: Admin can hard delete with approval + audit
async function hardDeleteBooking(bookingId: string, adminId: string, reason: string) {
  // Only admin with approval
  const approval = await ApprovalService.request({
    action: 'booking.hard_delete',
    resourceId: bookingId,
    requestedBy: adminId,
    reason,
    requiresRoles: ['admin']
  })
  
  if (!approval.approved) {
    throw new ApprovalRequiredError()
  }
  
  await AuditService.log({
    action: 'booking.hard_delete',
    userId: adminId,
    resourceId: bookingId,
    reason,
    approvalId: approval.id,
    severity: 'critical'
  })
  
  await prisma.booking.delete({ where: { id: bookingId } })
}
```

### Rule 4: Every Critical Action Emits Events

```typescript
// ❌ NEVER DO THIS - No event emission
async function confirmBooking(id: string) {
  return await prisma.booking.update({
    where: { id },
    data: { status: 'confirmed' }
  })
}

// ✅ ALWAYS DO THIS - Event-driven
async function confirmBooking(id: string, userId: string) {
  // 1. Update database
  const booking = await prisma.$transaction(async (tx) => {
    const updated = await tx.booking.update({
      where: { id },
      data: { 
        status: 'confirmed',
        confirmedAt: new Date(),
        confirmedBy: userId
      }
    })
    
    // Lock inventory
    await tx.equipment.updateMany({
      where: { id: { in: updated.equipmentIds } },
      data: { status: 'locked' }
    })
    
    return updated
  })
  
  // 2. Emit event (triggers downstream actions)
  await EventBus.emit('booking.confirmed', {
    bookingId: id,
    booking,
    userId,
    timestamp: new Date()
  })
  
  // Event handlers automatically triggered:
  // - Send confirmation email
  // - Generate contract
  // - Notify warehouse
  // - Update analytics
  // - Create invoice
  
  return booking
}
```

