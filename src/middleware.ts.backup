/**
 * @file middleware.ts
 * @description Next.js middleware for route protection and read-only mode
 * @module middleware
 */

import { auth } from '@/lib/auth'
import { NextResponse } from 'next/server'
import { enforceReadOnly } from '@/lib/middleware/read-only.middleware'

export default auth((req) => {
  const { pathname } = req.nextUrl
  const session = req.auth

  // Enforce read-only mode for write operations
  if (pathname.startsWith('/api')) {
    const readOnlyResponse = enforceReadOnly(req)
    if (readOnlyResponse) {
      return readOnlyResponse
    }
  }

  // Protect admin routes
  if (pathname.startsWith('/admin')) {
    if (!session || session.user?.role !== 'ADMIN') {
      return NextResponse.redirect(new URL('/login', req.url))
    }
  }

  // Protect dashboard routes
  if (pathname.startsWith('/dashboard')) {
    if (!session) {
      return NextResponse.redirect(new URL('/login', req.url))
    }
  }

  return NextResponse.next()
})

export const config = {
  matcher: ['/admin/:path*', '/dashboard/:path*'],
}
